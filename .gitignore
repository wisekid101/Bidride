# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/
.expo/
*.tsbuildinfo

# Expo prebuild native projects (generated — never commit)
apps/*/ios/
apps/*/android/

# Environment files (never commit secrets)
.env
.env.local
.env.*.local
!.env.example

# Logs
*.log
logs/
npm-debug.log*
pnpm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/

# Test / coverage
coverage/
.nyc_output/

# Prisma generated client (regenerated by prisma generate)
packages/database/generated/

# Turborepo cache
.turbo/

# Playwright
test-results/
playwright-report/

# Terraform state and secrets (never commit)
infrastructure/terraform/*.tfstate
infrastructure/terraform/*.tfstate.backup
infrastructure/terraform/.terraform/
infrastructure/terraform/.terraform.lock.hcl
infrastructure/terraform/terraform.tfvars
infrastructure/terraform/bidride.tfplan
