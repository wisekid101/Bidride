# Copy to .env and fill in real values. Never commit .env.

# Google Maps iOS SDK key — consumed at prebuild time by plugins/withGoogleMapsIOS.
# No EXPO_PUBLIC_ prefix on purpose: it must not be inlined into the JS bundle.
# Restrict this key in Google Cloud console to bundle ID com.bidride.rider
# and the "Maps SDK for iOS" API before distributing any build.
GOOGLE_MAPS_IOS_API_KEY=

# Backend API base URL. For device builds use your machine's LAN IP
# (e.g. http://192.168.x.x:8080); for the simulator use http://localhost:8080.
EXPO_PUBLIC_API_URL=http://localhost:8080

# Stripe publishable key (test mode: pk_test_...). Read at runtime by app/_layout.tsx.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
