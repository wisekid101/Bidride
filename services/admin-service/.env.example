# Admin Service — Port 3011
NODE_ENV=development
PORT=3011

# Database
DATABASE_URL=postgresql://bidride_user:password@localhost:5432/bidride_dev

# JWT (admin portal sessions)
JWT_SECRET=your-jwt-secret-min-32-chars
ADMIN_JWT_SECRET=your-admin-jwt-secret

# Founder JWT (earnings floor formula updates — Founder only)
FOUNDER_JWT_SECRET=founder-only-jwt-secret

# Stripe (refunds)
STRIPE_SECRET_KEY=replace-with-stripe-test-secret-key

# Internal service health endpoints
AUTH_SERVICE_URL=http://localhost:3001
TRIP_SERVICE_URL=http://localhost:3002
DRIVER_SERVICE_URL=http://localhost:3003
RIDER_SERVICE_URL=http://localhost:3004
PRICING_SERVICE_URL=http://localhost:3005
SAFETY_SERVICE_URL=http://localhost:3006
PAYMENT_SERVICE_URL=http://localhost:3007
NOTIFICATION_SERVICE_URL=http://localhost:3008
TRUST_SERVICE_URL=http://localhost:3009
AIRPORT_SERVICE_URL=http://localhost:3010
