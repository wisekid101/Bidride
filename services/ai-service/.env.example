# AI Service — Port 3012 (VPC-internal only — NOT exposed through ALB)
NODE_ENV=development
PORT=3012

# Redis (pub/sub, caching)
REDIS_URL=redis://localhost:6379

# Internal service key — must match INTERNAL_SERVICE_KEY in all calling services
# (trip-service, pricing-service, trust-service, admin-service)
INTERNAL_SERVICE_KEY=your-internal-service-key-min-32-chars

# AWS Region (for SageMaker, CloudWatch)
AWS_REGION=us-east-1
