# Airport Service — Port 3010
NODE_ENV=development
PORT=3010

# Database
DATABASE_URL=postgresql://bidride_user:password@localhost:5432/bidride_dev

# Redis (EWR FIFO queue)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars

# FlightAware AeroAPI
FLIGHTAWARE_API_KEY=your-flightaware-api-key
FLIGHTAWARE_CACHE_TTL_SECONDS=30

# EWR surge cap (business rule — do not change without founder approval)
EWR_SURGE_MAX_MULTIPLIER=2.5
EWR_SURGE_ADMIN_CONFIRM_ABOVE=1.5

# EWR terminal GPS coordinates (used for proximity checks)
EWR_LAT=40.6895
EWR_LNG=-74.1745
EWR_RADIUS_MILES=2.0
