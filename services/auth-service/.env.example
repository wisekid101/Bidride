# Auth Service — Port 3001
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://bidride_user:password@localhost:5432/bidride_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your-refresh-secret-min-32-chars
REFRESH_TOKEN_EXPIRES_IN=7d

# Twilio OTP
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15551234567
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# TOTP / FIDO2 MFA
TOTP_SECRET_ENCRYPTION_KEY=32-byte-hex-key-for-totp-encryption
FIDO2_ORIGIN=https://app.bidride.com
FIDO2_RP_ID=bidride.com

# Founder admin (seeded via db:seed)
FOUNDER_EMAIL=founder@bidride.com
FOUNDER_JWT_SECRET=founder-only-jwt-secret
