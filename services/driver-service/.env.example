# Driver Service — Port 3003
NODE_ENV=development
PORT=3003

# Database
DATABASE_URL=postgresql://bidride_user:password@localhost:5432/bidride_dev

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars

# AWS S3 (driver document uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET_NAME=bidride-driver-documents-dev
S3_PRESIGNED_URL_EXPIRES_SECONDS=900

# Checkr background checks
CHECKR_API_KEY=your-checkr-api-key
CHECKR_WEBHOOK_SECRET=your-checkr-webhook-secret
CHECKR_PACKAGE=driver_pro

# Admin JWT (for admin-only endpoints)
ADMIN_JWT_SECRET=your-admin-jwt-secret
