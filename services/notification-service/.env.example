# Notification Service — Port 3008
NODE_ENV=development
PORT=3008

# Database (audit log)
DATABASE_URL=postgresql://bidride_user:password@localhost:5432/bidride_dev

# Twilio SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15551234567
TWILIO_PROXY_SERVICE_SID=KSxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS SES (transactional email)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
SES_FROM_EMAIL=hello@bidride.com

# Firebase Cloud Messaging (FCM HTTP v1)
FCM_PROJECT_ID=bidride-prod
FCM_CLIENT_EMAIL=firebase-adminsdk@bidride-prod.iam.gserviceaccount.com
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
