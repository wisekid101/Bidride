# Payment Service — Port 3007
NODE_ENV=development
PORT=3007

# Database
DATABASE_URL=postgresql://bidride_user:password@localhost:5432/bidride_dev

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars

# Stripe Connect
STRIPE_SECRET_KEY=replace-with-stripe-test-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret

# Instant payout settings
INSTANT_PAYOUT_FEE=0.99
INSTANT_PAYOUT_MIN=10.00
INSTANT_PAYOUT_MAX=500.00
WALLET_HOLD_HOURS=2

# Payout containment kill-switch. Instant payouts are DISABLED unless this is
# exactly the string "true". Keep OFF (unset or false) in every environment
# until the durable payout allocation pipeline is complete and approved.
PAYOUTS_ENABLED=false

# Internal service URLs
NOTIFICATION_SERVICE_URL=http://localhost:3008
