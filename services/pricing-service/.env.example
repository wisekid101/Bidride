# Pricing Service — Port 3005
NODE_ENV=development
PORT=3005

# Database
DATABASE_URL=postgresql://bidride_user:password@localhost:5432/bidride_dev

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars

# AWS SageMaker (AI fare prediction)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
SAGEMAKER_ENDPOINT_NAME=bidride-fare-predictor-prod

# Pricing constants
BASE_FARE=2.50
RATE_PER_MILE=1.80
RATE_PER_MINUTE=0.35
SURGE_MAX_MULTIPLIER=2.5
AI_FARE_DELTA_CAP=2.00
