# Rider Service — Port 3004
NODE_ENV=development
PORT=3004

# Database
DATABASE_URL=postgresql://bidride_user:password@localhost:5432/bidride_dev

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars

# Stripe (rider payment methods)
STRIPE_SECRET_KEY=replace-with-stripe-test-secret-key
STRIPE_PUBLISHABLE_KEY=replace-with-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
