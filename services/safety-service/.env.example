# Safety Service — Port 3006
NODE_ENV=development
PORT=3006

# Database
DATABASE_URL=postgresql://bidride_user:password@localhost:5432/bidride_dev

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars

# AWS S3 (SOS audio recordings)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET_SOS_AUDIO=bidride-sos-audio-dev

# Internal service URLs
NOTIFICATION_SERVICE_URL=http://localhost:3008
ADMIN_SERVICE_URL=http://localhost:3011

# SOS countdown duration (seconds)
SOS_COUNTDOWN_SECONDS=5
