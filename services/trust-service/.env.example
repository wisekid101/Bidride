# Trust Service — Port 3009
NODE_ENV=development
PORT=3009

# Database
DATABASE_URL=postgresql://bidride_user:password@localhost:5432/bidride_dev

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars

# Trust score thresholds (internal — never exposed to users)
TRUST_SCORE_VERIFIED_MIN=0
TRUST_SCORE_TRUSTED_MIN=70
TRUST_SCORE_BUSINESS_MIN=80
TRUST_SCORE_VIP_MIN=90

# Fraud detection
FRAUD_AUTO_HOLD_PROBABILITY=0.90

# Internal service URLs
NOTIFICATION_SERVICE_URL=http://localhost:3008
ADMIN_SERVICE_URL=http://localhost:3011
