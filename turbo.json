{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:int": {
      "dependsOn": ["^build"],
      "cache": false,
      "passThroughEnv": [
        "DATABASE_URL",
        "TEST_DATABASE_URL",
        "REDIS_URL",
        "TEST_REDIS_URL",
        "JWT_SECRET",
        "NODE_ENV"
      ]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "migrate:dev": {
      "cache": false
    },
    "migrate:deploy": {
      "cache": false
    },
    "seed": {
      "cache": false
    },
    "studio": {
      "cache": false,
      "persistent": true
    }
  }
}
